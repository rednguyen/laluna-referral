# Email Configuration (Required for sending emails)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Hotel Email (Receives notifications of new coupons)
HOTEL_EMAIL=hotel-email@gmail.com

# Zalo Chatbot Configuration (Optional - for sending notifications to Zalo)
ZALO_BOT_TOKEN=your_zalo_bot_token_here
ZALO_CHAT_ID=your_zalo_chat_id_here

# Server Port
PORT=3001
