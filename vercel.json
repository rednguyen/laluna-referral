{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "installCommand": "npm install && cd client && npm install",
  "rewrites": [
    {
      "source": "/api/submit-coupon",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/tailors",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/client/dist/index.html"
    }
  ]
}
